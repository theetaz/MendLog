# Copy to .env.deploy (gitignored) and fill in real values.

# Firebase App Distribution Android app ID.
# Firebase Console → Project settings → General → Your apps → Android App ID.
FIREBASE_APP_ID=

# CI token for firebase-tools. Generate once with:
#   npx firebase-tools login:ci
# Paste the printed token here.
FIREBASE_TOKEN=

# Optional: comma-separated tester group aliases.
# Defaults to "field-testers" if unset.
FIREBASE_TESTER_GROUPS=field-testers

# Sentry auth token for sourcemap + debug-symbol uploads during the gradle build.
# Generate at: Sentry → Settings → Account → Auth Tokens (org-scoped).
# Without this, crashes still report but stack traces stay minified/obfuscated.
SENTRY_AUTH_TOKEN=
